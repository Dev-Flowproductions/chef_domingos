# Copy to supabase/.env for: npx supabase functions serve --env-file supabase/.env
# Never commit supabase/.env (gitignored via .env*.local pattern — add supabase/.env manually)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

LKM_BASE_URL=https://api-loyalty-pp.mymobile.pt
LKM_TOKEN_APP=your-lkm-token-app
LKM_HMAC_SECRET=your-lkm-partner-key
LKM_STORE_EXTERNAL_ID=2
