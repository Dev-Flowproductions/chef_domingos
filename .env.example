# Supabase (App)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# LKM Loyalty API — set these as Supabase Edge Function secrets (never expose in app)
# supabase secrets set LKM_BASE_URL=... LKM_TOKEN_APP=... LKM_HMAC_SECRET=... LKM_STORE_EXTERNAL_ID=...
LKM_BASE_URL=https://lkm-api.example.com
LKM_TOKEN_APP=your-lkm-app-token
LKM_HMAC_SECRET=your-hmac-secret
LKM_STORE_EXTERNAL_ID=your-store-id
