# Supabase (Expo app — EXPO_PUBLIC_* are bundled into the client)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# LKM Loyalty API — server-side only (Supabase Edge Function secrets)
# Pré-Produção: https://api-loyalty-pp.mymobile.pt
# Produção:     https://api-loyalty.myclient.pt
#
# LKM_HMAC_SECRET is the PartnerKey from LKM (HMAC-SHA256 signing).
# Push to your Supabase project:
#   npx supabase secrets set --project-ref YOUR_REF \
#     LKM_BASE_URL=https://api-loyalty-pp.mymobile.pt \
#     LKM_TOKEN_APP=your-token-app \
#     LKM_HMAC_SECRET=your-partner-key \
#     LKM_STORE_EXTERNAL_ID=2
#
# Local copy for development: duplicate these into .env.local (gitignored).
LKM_BASE_URL=https://api-loyalty-pp.mymobile.pt
LKM_TOKEN_APP=your-lkm-token-app
LKM_HMAC_SECRET=your-lkm-partner-key
LKM_STORE_EXTERNAL_ID=2
